# Server
PORT=3001
NODE_ENV=development

# Database
MONGODB_URI=mongodb://localhost:27017/h_wallet

# OKX OnchainOS Agent Wallet API
# 请参考：https://web3.okx.com/build/docs/waas/agent-wallet-overview
OKX_API_BASE_URL=https://www.okx.com
OKX_API_KEY=your_okx_api_key_here
OKX_API_SECRET=your_okx_api_secret_here
OKX_API_PASSPHRASE=your_okx_api_passphrase_here

# RSA Keys for password encryption (Generate using: openssl genrsa -out private.pem 2048)
# Then extract public key: openssl rsa -in private.pem -pubout -out public.pem
RSA_PRIVATE_KEY=`-----BEGIN RSA PRIVATE KEY-----
... (Your full private key here) ...
-----END RSA PRIVATE KEY-----`
# RSA_PUBLIC_KEY will be generated from private key in code, but you can also set it here if needed.