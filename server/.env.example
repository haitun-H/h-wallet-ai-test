# 服务器配置
NODE_ENV=development
PORT=8080
BASE_URL=http://localhost:8080/v1

# JWT 配置
JWT_SECRET=your-super-secret-jwt-key-at-least-32-characters-long
JWT_ACCESS_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d

# 应用配置
VERIFICATION_CODE_EXPIRY=300 # 验证码有效期（秒）
VERIFICATION_CODE_COOLDOWN=60 # 验证码冷却时间（秒）
WALLET_CREATION_MAX_RETRIES=3 # 钱包创建最大重试次数

# 日志配置
LOG_LEVEL=info
LOG_FILE=logs/app.log

# 数据库配置（MVP阶段使用内存存储，生产环境需替换）
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=h_wallet
# DB_USER=postgres
# DB_PASSWORD=postgres
