import React from 'react';
import {
  View,
  Text,
  TouchableOpacity,
  StyleSheet,
  Linking,
} from 'react-native';
import { Ionicons } from '@expo/vector-icons';

interface CheckboxProps {
  isChecked: boolean;
  onToggle: () => void;
  error?: string | null;
}

const TERMS_LINK = 'https://h-wallet.com/terms'; // TODO: 替换为实际条款链接

const Checkbox: React.FC<CheckboxProps> = ({ isChecked, onToggle, error }) => {
  const handleTermsPress = () => {
    Linking.openURL(TERMS_LINK).catch((err) =>
      console.error('Failed to open terms link:', err)
    );
  };

  return (
    <View style={styles.container}>
      <TouchableOpacity style={styles.checkboxRow} onPress={onToggle} activeOpacity={0.7}>
        <View style={[styles.checkbox, isChecked && styles.checkboxChecked]}>
          {isChecked && (
            <Ionicons name="checkmark" size={16} color="#FFFFFF" />
          )}
        </View>
        <Text style={styles.label}>
          我已阅读并同意
          <Text style={styles.link} onPress={handleTermsPress}>
            《服务条款》
          </Text>
        </Text>
      </TouchableOpacity>
      {error ? <Text style={styles.errorText}>{error}</Text> : null}
    </View>
  );
};

const styles = StyleSheet.create({
  container: {
    marginBottom: 24,
  },
  checkboxRow: {
    flexDirection: 'row',
    alignItems: 'center',
  },
  checkbox: {
    width: 20,
    height: 20,
    borderRadius: 4,
    borderWidth: 2,
    borderColor: '#D1D5DB',
    marginRight: 12,
    justifyContent: 'center',
    alignItems: 'center',
    backgroundColor: '#FFFFFF',
  },
  checkboxChecked: {
    backgroundColor: '#3B82F6',
    borderColor: '#3B82F6',
  },
  label: {
    fontSize: 14,
    color: '#6B7280',
    flex: 1,
    flexWrap: 'wrap',
  },
  link: {
    color: '#3B82F6',
    fontWeight: '500',
  },
  errorText: {
    fontSize: 14,
    color: '#EF4444',
    marginTop: 4,
  },
});

export default Checkbox;