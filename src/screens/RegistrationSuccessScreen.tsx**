import { RouteProp, useNavigation, useRoute } from '@react-navigation/native';
import { NativeStackNavigationProp } from '@react-navigation/native-stack';
import * as Clipboard from 'expo-clipboard';
import { Ionicons } from '@expo/vector-icons';
import Button from '../components/Button';

type RootStackParamList = {
  RegisterSuccess: { walletAddress: string };
  Home: undefined;
};

type RegistrationSuccessScreenRouteProp = RouteProp<RootStackParamList, 'RegisterSuccess'>;
type RegistrationSuccessScreenNavigationProp = NativeStackNavigationProp<RootStackParamList, 'Home'>;

const RegistrationSuccessScreen: React.FC = () => {
  const route = useRoute<RegistrationSuccessScreenRouteProp>();
  const navigation = useNavigation<RegistrationSuccessScreenNavigationProp>();
  const { walletAddress } = route.params;

  const handleCopyAddress = async () => {
    await Clipboard.setStringAsync(walletAddress);
    Alert.alert('已复制', '钱包地址已复制到剪贴板。');
  };

  const handleGoToWallet = () => {
    // TODO: 实现跳转到主页
    navigation.navigate('Home');
    console.log('Navigate to Home');
  };

  return (
    <SafeAreaView style={styles.safeArea}>
      <ScrollView
        contentContainerStyle={styles.scrollContent}
        showsVerticalScrollIndicator={false}
      >
        <View style={styles.content}>
          {/* Success Animation Placeholder */}
          <View style={styles.animationPlaceholder}>
            <Ionicons name="checkmark-circle" size={120} color="#10B981" />
            {/* TODO: 替换为 Lottie 动画 */}
            {/* <LottieView source={require('../assets/success.json')} autoPlay loop={false} /> */}
          </View>

          <Text style={styles.title}>欢迎加入 H Wallet！</Text>
          <Text style={styles.message}>您的专属钱包已创建成功</Text>

          <View style={styles.walletCard}>
            <Text style={styles.walletLabel}>您的钱包地址</Text>
            <Text style={styles.walletAddress} numberOfLines={1} ellipsizeMode="middle">
              {walletAddress}
            </Text>
            <TouchableOpacity style={styles.copyButton} onPress={handleCopyAddress}>
              <Ionicons name="copy-outline" size={18} color="#3B82F6" />
              <Text style={styles.copyButtonText}>复制</Text>
            </TouchableOpacity>
          </View>

          <Button
            title="进入钱包"
            onPress={handleGoToWallet}
            variant="secondary"
            style={styles.actionButton}
          />
        </View>
      </ScrollView>
    </SafeAreaView>
  );
};

